#!/usr/bin/env bash
# meeting — agent-agnostic meeting recorder + local transcriber.
#
# Two-layer design: this CLI does only the part agents can't do —
# capture audio (ffmpeg) and transcribe locally (whisper.cpp). The smart
# half (summary / decisions / action items / routing) is left to whatever
# host agent calls this CLI (Claude Code skill, Codex command, …).
#
# Realtime control (start/stop/status) is meant to be run DIRECTLY in a
# terminal for instant, unambiguous feedback — the agent path adds an LLM
# round-trip and can't render live feedback while idle. Final stdout of
# transcribe/stop is ALWAYS the transcript path (chatter goes to stderr).
set -euo pipefail

MEETING_HOME="${MEETING_HOME:-$HOME/.meeting}"
REC_DIR="$MEETING_HOME/recordings"
MODEL_DIR="$MEETING_HOME/models"
NOTES_DIR="$MEETING_HOME/notes"
STATE="$MEETING_HOME/state"
PIDFILE="$MEETING_HOME/recording.pid"
LOG="$MEETING_HOME/ffmpeg.log"

MODEL="${MEETING_MODEL:-$MODEL_DIR/ggml-large-v3-turbo.bin}"
AUDIO_INPUT="${MEETING_AUDIO_INPUT:-:0}"   # avfoundation audio index; see `meeting devices`
LANG_OPT="${MEETING_LANG:-auto}"           # zh / en / auto
MAX_MIN="${MEETING_MAX_MIN:-180}"          # auto-stop after N min (0 = no cap) — prevents runaway recordings
MIN_FREE_MB="${MEETING_MIN_FREE_MB:-500}"  # warn if free disk < this before recording
MODEL_URL="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo.bin"
ASR="${MEETING_ASR:-whisper}"              # transcription backend: whisper(default) / openai / deepgram / faster-whisper / …

# Resolve the repo's backends/ dir (this script may be symlinked into ~/.local/bin).
_self="${BASH_SOURCE[0]:-$0}"
while [ -L "$_self" ]; do _l="$(readlink "$_self")"; case "$_l" in /*) _self="$_l";; *) _self="$(dirname "$_self")/$_l";; esac; done
BACKENDS_DIR="${MEETING_BACKENDS_DIR:-$(cd "$(dirname "$_self")/.." 2>/dev/null && pwd)/backends}"

mkdir -p "$REC_DIR" "$MODEL_DIR" "$NOTES_DIR"

die(){ echo "meeting: $*" >&2; exit 1; }
whisper_bin(){ command -v whisper-cli 2>/dev/null || command -v whisper-cpp 2>/dev/null || true; }
elapsed(){ grep -o 'time=[0-9:.]*' "$LOG" 2>/dev/null | tail -1 | cut -d= -f2; }
cap_sec(){ echo $(( (MAX_MIN > 0 ? MAX_MIN : 999999) * 60 )); }   # ffmpeg -t value
cap_note(){ [ "$MAX_MIN" -gt 0 ] 2>/dev/null && printf '上限 %s 分钟自动停(MEETING_MAX_MIN=0 取消)' "$MAX_MIN"; }

# Warn (don't block) if disk is low — a full disk corrupts the recording tail.
disk_warn(){
  free_mb=$(df -m "$REC_DIR" 2>/dev/null | awk 'NR==2{print $4}')
  case "${free_mb:-}" in (''|*[!0-9]*) return 0;; esac
  [ "$free_mb" -lt "$MIN_FREE_MB" ] && echo "⚠ 磁盘剩余约 ${free_mb}MB(录音约 2MB/分钟,注意空间)。" >&2
  return 0
}

# Count recordings with no sibling .txt (e.g. left by a crash/hard-kill).
orphan_count(){
  n=0; for w in "$REC_DIR"/*.wav; do [ -e "$w" ] || continue; [ -f "${w%.*}.txt" ] || n=$((n+1)); done; echo "$n"
}

cmd_devices(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  echo "Audio inputs (use the [n] index as MEETING_AUDIO_INPUT=:n):" >&2
  ffmpeg -hide_banner -f avfoundation -list_devices true -i "" 2>&1 \
    | sed -n '/AVFoundation audio devices/,$p' || true
}

cmd_start(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    die "already recording (pid $(cat "$PIDFILE")). run 'meeting stop' first."
  fi
  disk_warn
  ts="$(/bin/date +%Y%m%d-%H%M%S)"
  out="$REC_DIR/$ts.wav"
  echo "$out" > "$STATE"
  : > "$LOG"
  nohup ffmpeg -hide_banner -nostdin -f avfoundation -i "$AUDIO_INPUT" \
    -ar 16000 -ac 1 -t "$(cap_sec)" -y "$out" >"$LOG" 2>&1 &
  pid=$!; echo "$pid" > "$PIDFILE"; disown 2>/dev/null || true
  # Verify capture actually began (catches denied mic permission) before claiming success.
  sleep 1.5
  if kill -0 "$pid" 2>/dev/null && grep -q "size=" "$LOG" && ! grep -qi "error opening input\|input/output error" "$LOG"; then
    {
      echo "┌──────────────────────────────────────────────"
      echo "│ ●REC  正在录音 — 已确认音频写入 ✓"
      echo "│ 文件 $out"
      echo "│ 设备 $AUDIO_INPUT    pid $pid    $(cap_note)"
      echo "│ 看状态: meeting status      结束: meeting stop"
      echo "└──────────────────────────────────────────────"
    } >&2
  else
    rm -f "$PIDFILE"
    {
      echo "✗ 录音没起来 —— 最可能是终端没拿到「麦克风」权限。"
      echo "  系统设置 ▸ 隐私与安全性 ▸ 麦克风 → 勾上你的终端,再 meeting start。"
      echo "  ffmpeg 日志: $LOG"
    } >&2
    exit 1
  fi
}

cmd_status(){
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "●REC 正在录音   已录 $(elapsed)   pid $(cat "$PIDFILE")   → $(cat "$STATE" 2>/dev/null)"
  else
    echo "○ 当前未在录音"
    n="$(orphan_count)"; [ "$n" -gt 0 ] && echo "  ⚠ $n 个录音还没转录(可能上次崩了)→ meeting recover" >&2
  fi
  return 0
}

# Foreground recorder with a LIVE level meter — the snappy, unambiguous path.
# Run this directly in a terminal (NOT via the agent): instant start, a bar that
# moves with your voice (so you SEE it's capturing), Ctrl-C to stop + transcribe.
cmd_rec(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    die "a background recording (meeting start) is running — 'meeting stop' it first."
  fi
  disk_warn
  ts="$(/bin/date +%Y%m%d-%H%M%S)"; out="$REC_DIR/$ts.wav"; echo "$out" > "$STATE"
  {
    echo "●REC 前台录音 — 对着麦说话,电平条会跟着跳。Ctrl-C 结束并自动转录。$(cap_note)"
    echo "  → $out"
  } >&2
  trap 'true' INT   # let ffmpeg catch Ctrl-C & finalize the wav; keep this script alive to transcribe after
  # ebur128 passes audio through to the wav AND prints momentary loudness (M:) to stderr.
  ffmpeg -hide_banner -nostdin -f avfoundation -i "$AUDIO_INPUT" \
    -af ebur128 -ar 16000 -ac 1 -t "$(cap_sec)" -y "$out" 2>&1 \
  | awk -v W=28 '
      function bar(v,   f,n,i,s){ f=(v+50)/40; if(f<0)f=0; if(f>1)f=1; n=int(f*W); s=""; for(i=0;i<W;i++) s=s (i<n?"\342\226\210":" "); return s }
      / M:/ { t=""; m=""; for(i=1;i<=NF;i++){ if($i=="t:") t=$(i+1); if($i=="M:") m=$(i+1) }
              if(m=="" || m=="nan" || m=="-nan") next;
              sec=int(t+0); mm=int(sec/60); ss=sec%60;
              printf("\r\033[K\033[32m●REC\033[0m %02d:%02d  [%s] %6.1f LUFS   [Ctrl-C 结束]", mm, ss, bar(m+0), m+0) > "/dev/stderr"; fflush() }
    ' || true
  trap - INT
  printf "\n" >&2
  [ -s "$out" ] || die "recording empty: $out (mic permission? see above)"
  size="$(ls -lh "$out" | awk '{print $5}')"
  echo "■ 录音已结束 STOPPED  大小 ${size}  → $out" >&2
  cmd_transcribe "$out"
}

cmd_stop(){
  [ -f "$PIDFILE" ] || die "not recording."
  pid="$(cat "$PIDFILE")"; out="$(cat "$STATE")"; dur="$(elapsed)"
  kill -INT "$pid" 2>/dev/null || true          # SIGINT → ffmpeg finalizes the wav
  for _ in $(seq 1 50); do kill -0 "$pid" 2>/dev/null || break; sleep 0.2; done
  rm -f "$PIDFILE"
  [ -s "$out" ] || die "recording empty: $out (mic permission? see $LOG)"
  size="$(ls -lh "$out" | awk '{print $5}')"
  # Instant, unambiguous "recording ended" BEFORE the (slower) transcription step.
  {
    echo "■ 录音已结束  STOPPED   时长 ${dur:-?}   大小 ${size}"
    echo "  $out"
  } >&2
  cmd_transcribe "$out"
}

# whisper initial prompt = a glossary of YOUR domain terms / proper nouns, so whisper
# spells them right (e.g. 具身/Embodiment not 巨神). Source: $MEETING_PROMPT, else
# ~/.meeting/glossary.txt — which the host agent maintains from your Claude Code
# memory / repo / past transcripts. The CLI just reads it; it doesn't decide content.
meeting_prompt(){
  if [ -n "${MEETING_PROMPT:-}" ]; then printf '%s' "$MEETING_PROMPT"; return; fi
  [ -f "$MEETING_HOME/glossary.txt" ] && tr '\n' ' ' < "$MEETING_HOME/glossary.txt"
}

cmd_transcribe(){
  audio="${1:-$(cat "$STATE" 2>/dev/null || true)}"
  [ -n "$audio" ] && [ -f "$audio" ] || die "no audio file to transcribe."
  base="${audio%.*}"; prompt="$(meeting_prompt)"
  # Foolproofing: a Ctrl-C here is SAFE (audio is already on disk). Say so loudly + how to resume.
  trap 'printf "\n" >&2; echo "⚠ 转录已中断 —— 音频安全保存在: $audio" >&2; echo "  随时补转录:  meeting transcribe \"$audio\"   (或 meeting recover)" >&2; exit 130' INT
  if [ "$ASR" = "whisper" ]; then
    # default: local whisper.cpp — offline, private. -otxt clean text, -osrt timestamps.
    bin="$(whisper_bin)"; [ -n "$bin" ] || die "whisper.cpp not installed — run: meeting setup"
    [ -f "$MODEL" ] || die "model missing: $MODEL — run: meeting setup"
    echo "… 本地转录中 (whisper: $(basename "$MODEL"))$([ -n "$prompt" ] && printf ' + 术语表')  —— 可 Ctrl-C 中断(音频已存);进度见下方 …" >&2
    if [ -n "$prompt" ]; then
      "$bin" -m "$MODEL" -f "$audio" -l "$LANG_OPT" --prompt "$prompt" -pp -otxt -osrt -of "$base" 1>/dev/null
    else
      "$bin" -m "$MODEL" -f "$audio" -l "$LANG_OPT" -pp -otxt -osrt -of "$base" 1>/dev/null
    fi
  else
    # pluggable backend: backends/<ASR>.sh  (contract: writes $base.txt [+ $base.srt])
    be="$BACKENDS_DIR/$ASR.sh"
    [ -f "$be" ] || die "未知 MEETING_ASR='$ASR'(找不到 $be)。内置:whisper(默认)/openai/deepgram/faster-whisper;见 backends/README.md"
    case "$ASR" in openai|deepgram|assemblyai|elevenlabs|xfyun|alibaba)
      echo "⚠ 后端 '$ASR' 会把音频上传到云端 —— 要全本地请用 MEETING_ASR=whisper。" >&2 ;;
    esac
    echo "… 用 '$ASR' 后端转录中(音频已存,中断可 meeting recover)…" >&2
    MEETING_PROMPT_TEXT="$prompt" bash "$be" "$audio" "$base" "$LANG_OPT"
    [ -f "$base.txt" ] || die "后端 '$ASR' 未产出转录稿($base.txt)"
  fi
  trap - INT
  echo "✓ 转录完成 → $base.txt$([ -f "$base.srt" ] && printf '   (带时间戳: %s.srt)' "$base")" >&2
  echo "$base.txt"      # <- final stdout: the transcript path
}

cmd_glossary(){
  p="$(meeting_prompt)"
  echo "喂给 whisper --prompt 的术语表:" >&2
  if [ -n "$p" ]; then printf '%s\n' "$p"
  else echo "(空 —— 由 agent 从 memory/repo/历史转录整理后写入 $MEETING_HOME/glossary.txt)" >&2; fi
}

# Recover orphaned recordings: any .wav without a sibling .txt (left by a crash /
# hard kill / power loss). Re-mux through ffmpeg to repair a possibly-unfinalized
# WAV header, then transcribe. Safe to run anytime; idempotent.
cmd_recover(){
  found=0
  for wav in "$REC_DIR"/*.wav; do
    [ -e "$wav" ] || continue
    base="${wav%.*}"
    [ -f "$base.txt" ] && continue                 # already transcribed
    [ -s "$wav" ] || { echo "跳过空文件 $wav" >&2; continue; }
    found=1
    echo "↻ 恢复 $wav …" >&2
    fixed="$base.fixed.wav"
    if ffmpeg -hide_banner -v error -y -i "$wav" -c copy "$fixed" 2>/dev/null && [ -s "$fixed" ]; then
      mv -f "$fixed" "$wav"                         # replace with header-repaired copy
    else
      rm -f "$fixed"                                # repair failed → try the original as-is
    fi
    ( cmd_transcribe "$wav" >/dev/null ) || echo "  ✗ 转录失败,保留原始音频: $wav" >&2
  done
  [ "$found" = 1 ] || echo "没有未转录的孤儿录音。" >&2
}

cmd_setup(){
  command -v brew >/dev/null || die "need Homebrew — see https://brew.sh"
  [ -n "$(whisper_bin)" ] || brew install whisper-cpp
  # (re)download if missing OR implausibly small (catches a truncated partial download).
  if [ ! -f "$MODEL" ] || [ "$(wc -c < "$MODEL" 2>/dev/null || echo 0)" -lt 100000000 ]; then
    echo "downloading model (~1.6GB) → $MODEL" >&2
    tmp="$MODEL.part"
    if curl -L --fail -o "$tmp" "$MODEL_URL"; then mv -f "$tmp" "$MODEL"; else rm -f "$tmp"; die "model download failed (network?). re-run: meeting setup"; fi
  fi
  echo "setup ok. whisper=$(whisper_bin) model=$MODEL" >&2
}

case "${1:-}" in
  rec)        cmd_rec ;;
  start)      cmd_start ;;
  stop)       cmd_stop ;;
  status)     cmd_status ;;
  transcribe) shift; cmd_transcribe "${1:-}" ;;
  recover)    cmd_recover ;;
  glossary)   cmd_glossary ;;
  devices)    cmd_devices ;;
  setup)      cmd_setup ;;
  *) echo "usage: meeting {rec|start|stop|status|transcribe [file]|recover|glossary|devices|setup}" >&2
     echo "  rec     前台录音+实时电平条(推荐,直接在终端跑;Ctrl-C 结束并转录)" >&2
     echo "  start   后台录音(给 agent/脚本用),配合 stop" >&2
     echo "  recover 把崩溃/断电留下的未转录录音修复并转录" >&2
     exit 1 ;;
esac
