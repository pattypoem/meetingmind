#!/usr/bin/env bash
# meeting — agent-agnostic meeting recorder + local transcriber.
#
# Two-layer design: this CLI does only the part agents can't do —
# capture audio (ffmpeg) and transcribe locally (whisper.cpp). The smart
# half (summary / decisions / action items / routing) is left to whatever
# host agent calls this CLI (Claude Code skill, Codex command, …).
#
# Realtime control (start/stop/status) is meant to be run DIRECTLY in a
# terminal for instant, unambiguous feedback — the agent path adds an LLM
# round-trip and can't render live feedback while idle. Final stdout of
# transcribe/stop is ALWAYS the transcript path (chatter goes to stderr).
set -euo pipefail

MEETING_HOME="${MEETING_HOME:-$HOME/.meeting}"
REC_DIR="$MEETING_HOME/recordings"
MODEL_DIR="$MEETING_HOME/models"
NOTES_DIR="$MEETING_HOME/notes"
STATE="$MEETING_HOME/state"
PIDFILE="$MEETING_HOME/recording.pid"
LOG="$MEETING_HOME/ffmpeg.log"

MODEL="${MEETING_MODEL:-$MODEL_DIR/ggml-large-v3-turbo.bin}"
AUDIO_INPUT="${MEETING_AUDIO_INPUT:-:0}"   # avfoundation audio index; see `meeting devices`
LANG_OPT="${MEETING_LANG:-auto}"           # zh / en / auto
MODEL_URL="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo.bin"

mkdir -p "$REC_DIR" "$MODEL_DIR" "$NOTES_DIR"

die(){ echo "meeting: $*" >&2; exit 1; }
whisper_bin(){ command -v whisper-cli 2>/dev/null || command -v whisper-cpp 2>/dev/null || true; }
elapsed(){ grep -o 'time=[0-9:.]*' "$LOG" 2>/dev/null | tail -1 | cut -d= -f2; }

cmd_devices(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  echo "Audio inputs (use the [n] index as MEETING_AUDIO_INPUT=:n):" >&2
  ffmpeg -hide_banner -f avfoundation -list_devices true -i "" 2>&1 \
    | sed -n '/AVFoundation audio devices/,$p' || true
}

cmd_start(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    die "already recording (pid $(cat "$PIDFILE")). run 'meeting stop' first."
  fi
  ts="$(/bin/date +%Y%m%d-%H%M%S)"
  out="$REC_DIR/$ts.wav"
  echo "$out" > "$STATE"
  : > "$LOG"
  nohup ffmpeg -hide_banner -nostdin -f avfoundation -i "$AUDIO_INPUT" \
    -ar 16000 -ac 1 -y "$out" >"$LOG" 2>&1 &
  pid=$!; echo "$pid" > "$PIDFILE"; disown 2>/dev/null || true
  # Verify capture actually began (catches denied mic permission) before claiming success.
  sleep 1.5
  if kill -0 "$pid" 2>/dev/null && grep -q "size=" "$LOG" && ! grep -qi "error opening input\|input/output error" "$LOG"; then
    {
      echo "┌──────────────────────────────────────────────"
      echo "│ ●REC  正在录音 — 已确认音频写入 ✓"
      echo "│ 文件 $out"
      echo "│ 设备 $AUDIO_INPUT    pid $pid"
      echo "│ 看状态: meeting status      结束: meeting stop"
      echo "└──────────────────────────────────────────────"
    } >&2
  else
    rm -f "$PIDFILE"
    {
      echo "✗ 录音没起来 —— 最可能是终端没拿到「麦克风」权限。"
      echo "  系统设置 ▸ 隐私与安全性 ▸ 麦克风 → 勾上你的终端,再 meeting start。"
      echo "  ffmpeg 日志: $LOG"
    } >&2
    exit 1
  fi
}

cmd_status(){
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo "●REC 正在录音   已录 $(elapsed)   pid $(cat "$PIDFILE")   → $(cat "$STATE" 2>/dev/null)"
  else
    echo "○ 当前未在录音"
  fi
}

# Foreground recorder with a LIVE level meter — the snappy, unambiguous path.
# Run this directly in a terminal (NOT via the agent): instant start, a bar that
# moves with your voice (so you SEE it's capturing), Ctrl-C to stop + transcribe.
cmd_rec(){
  command -v ffmpeg >/dev/null || die "missing ffmpeg — run: brew install ffmpeg"
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    die "a background recording (meeting start) is running — 'meeting stop' it first."
  fi
  ts="$(/bin/date +%Y%m%d-%H%M%S)"; out="$REC_DIR/$ts.wav"; echo "$out" > "$STATE"
  {
    echo "●REC 前台录音 — 对着麦说话,电平条会跟着跳。Ctrl-C 结束并自动转录。"
    echo "  → $out"
  } >&2
  trap 'true' INT   # let ffmpeg catch Ctrl-C & finalize the wav; keep this script alive to transcribe after
  # ebur128 passes audio through to the wav AND prints momentary loudness (M:) to stderr.
  ffmpeg -hide_banner -nostdin -f avfoundation -i "$AUDIO_INPUT" \
    -af ebur128 -ar 16000 -ac 1 -y "$out" 2>&1 \
  | awk -v W=28 '
      function bar(v,   f,n,i,s){ f=(v+50)/40; if(f<0)f=0; if(f>1)f=1; n=int(f*W); s=""; for(i=0;i<W;i++) s=s (i<n?"\342\226\210":" "); return s }
      / M:/ { t=""; m=""; for(i=1;i<=NF;i++){ if($i=="t:") t=$(i+1); if($i=="M:") m=$(i+1) }
              if(m=="" || m=="nan" || m=="-nan") next;
              sec=int(t+0); mm=int(sec/60); ss=sec%60;
              printf("\r\033[K\033[32m●REC\033[0m %02d:%02d  [%s] %6.1f LUFS   [Ctrl-C 结束]", mm, ss, bar(m+0), m+0) > "/dev/stderr"; fflush() }
    ' || true
  trap - INT
  printf "\n" >&2
  [ -s "$out" ] || die "recording empty: $out (mic permission? see above)"
  size="$(ls -lh "$out" | awk '{print $5}')"
  echo "■ 录音已结束 STOPPED  大小 ${size}  → $out" >&2
  cmd_transcribe "$out"
}

cmd_stop(){
  [ -f "$PIDFILE" ] || die "not recording."
  pid="$(cat "$PIDFILE")"; out="$(cat "$STATE")"; dur="$(elapsed)"
  kill -INT "$pid" 2>/dev/null || true          # SIGINT → ffmpeg finalizes the wav
  for _ in $(seq 1 50); do kill -0 "$pid" 2>/dev/null || break; sleep 0.2; done
  rm -f "$PIDFILE"
  [ -s "$out" ] || die "recording empty: $out (mic permission? see $LOG)"
  size="$(ls -lh "$out" | awk '{print $5}')"
  # Instant, unambiguous "recording ended" BEFORE the (slower) transcription step.
  {
    echo "■ 录音已结束  STOPPED   时长 ${dur:-?}   大小 ${size}"
    echo "  $out"
  } >&2
  cmd_transcribe "$out"
}

cmd_transcribe(){
  audio="${1:-$(cat "$STATE" 2>/dev/null || true)}"
  [ -n "$audio" ] && [ -f "$audio" ] || die "no audio file to transcribe."
  bin="$(whisper_bin)"; [ -n "$bin" ] || die "whisper.cpp not installed — run: meeting setup"
  [ -f "$MODEL" ] || die "model missing: $MODEL — run: meeting setup"
  base="${audio%.*}"
  echo "… 本地转录中 ($(basename "$MODEL"))  —— 进度见下方 …" >&2
  "$bin" -m "$MODEL" -f "$audio" -l "$LANG_OPT" -pp -otxt -of "$base" 1>/dev/null   # -pp = print progress (stderr)
  echo "✓ 转录完成 → $base.txt" >&2
  echo "$base.txt"      # <- final stdout: the transcript path
}

cmd_setup(){
  command -v brew >/dev/null || die "need Homebrew — see https://brew.sh"
  [ -n "$(whisper_bin)" ] || brew install whisper-cpp
  if [ ! -f "$MODEL" ]; then
    echo "downloading model (~1.6GB) → $MODEL" >&2
    curl -L --fail -o "$MODEL" "$MODEL_URL"
  fi
  echo "setup ok. whisper=$(whisper_bin) model=$MODEL" >&2
}

case "${1:-}" in
  rec)        cmd_rec ;;
  start)      cmd_start ;;
  stop)       cmd_stop ;;
  status)     cmd_status ;;
  transcribe) shift; cmd_transcribe "${1:-}" ;;
  devices)    cmd_devices ;;
  setup)      cmd_setup ;;
  *) echo "usage: meeting {rec|start|stop|status|transcribe [file]|devices|setup}" >&2
     echo "  rec   前台录音+实时电平条(推荐,直接在终端跑;Ctrl-C 结束并转录)" >&2
     echo "  start 后台录音(给 agent/脚本用),配合 stop" >&2
     exit 1 ;;
esac
